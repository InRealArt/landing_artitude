{
  "name": "nextjs-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "install:safe:prisma:inrealart": "npx dotenv-cli -e .env -- pnpm install @InRealArt/prisma-schema",
    "prisma:copy-schema": "cp node_modules/@InRealArt/prisma-schema/schema.prisma prisma/schema.prisma",
    "update:schema:inrealart": "pnpm run install:safe:prisma:inrealart && pnpm run prisma:copy-schema && npx prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@InRealArt/prisma-schema": "^1.4.5",
    "@types/leaflet": "^1.9.21",
    "autoprefixer": "^10.5.2",
    "exceljs": "^4.4.0",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.9",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sharp": "^0.32.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
